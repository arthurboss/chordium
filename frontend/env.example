# Frontend Environment Variables
# Copy this file to .env.local for local development

# API Configuration
VITE_API_URL=http://localhost:3001

# Render backend URL (for chord sheet and metadata endpoints requiring Puppeteer)
VITE_RENDER_URL=https://chordium-backend.onrender.com

# Vercel Configuration
VERCEL=0

# Build Configuration
NODE_ENV=development 
# Public app URL used for generating shareable QR code links
VITE_APP_URL=https://chordium.vercel.app
